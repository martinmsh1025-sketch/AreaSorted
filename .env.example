# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
APP_NAME=AreaSorted

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/areasorted

# Auth / sessions
SESSION_SECRET=replace-with-strong-random-secret
ADMIN_PASSWORD=replace-with-admin-password
CRON_SECRET=replace-with-cron-secret

# Stripe platform
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Stripe Connect defaults
CONNECTED_ACCOUNT_MODE=express
STRIPE_CHARGE_MODEL=direct_charges
STRIPE_DEFAULT_COUNTRY=GB
STRIPE_DEFAULT_CURRENCY=gbp
STRIPE_PAYOUT_HOLD_DAYS=7
STRIPE_MANUAL_PAYOUTS=true
ALLOW_MOCK_STRIPE_CHECKOUT=true

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=replace-with-google-maps-key

# Postcode lookup
SIMPLY_POSTCODE_API_KEY=replace-with-simply-postcode-key

# Marketplace commercial settings
MARKETPLACE_DEFAULT_BOOKING_FEE_GBP=12
MARKETPLACE_DEFAULT_COMMISSION_PERCENT=12
MARKETPLACE_DEFAULT_MARKUP_ENABLED=false
MARKETPLACE_DEFAULT_INVOICE_STRATEGY=provider_service_plus_platform_fee_receipt
MARKETPLACE_DEFAULT_REFUND_APPLICATION_FEE=false

# Notifications — Email (Resend recommended for production, SMTP for local dev)
# Option 1: Resend (recommended) — get API key from https://resend.com
RESEND_API_KEY=
# Option 2: SMTP (for local dev with MailHog etc.)
EMAIL_FROM=no-reply@areasorted.com
SUPPORT_EMAIL=support@areasorted.com
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# Document generation
INVOICE_BRAND_NAME=AreaSorted
INVOICE_NUMBER_PREFIX=AS
PROVIDER_INVOICE_NUMBER_PREFIX=PV

# File uploads — get token from https://uploadthing.com
UPLOADTHING_TOKEN=

# Logging
LOG_LEVEL=info

# Seeds / demo
SEED_ADMIN_EMAIL=admin@areasorted.com
SEED_PROVIDER_EMAIL=provider@example.com

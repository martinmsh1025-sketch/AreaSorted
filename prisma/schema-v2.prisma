generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  SUPER_ADMIN
  OPS_ADMIN
  REVIEWER
  SUPPORT
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum CleanerStatus {
  NEW
  PENDING_DOCS
  UNDER_REVIEW
  APPROVED
  CONTRACT_SENT
  ACTIVE
  SUSPENDED
  REJECTED
}

enum ApplicationSource {
  INDEED
  WEBSITE
  REFERRAL
  FACEBOOK
  OTHER
}

enum ApplicationStatus {
  SUBMITTED
  PENDING_DOCS
  UNDER_REVIEW
  APPROVED
  REJECTED
  MORE_INFO_REQUIRED
}

enum DocumentType {
  ID
  CV
  PHOTO
  RIGHT_TO_WORK
  ADDRESS_PROOF
  DBS
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_REUPLOAD
}

enum ReviewType {
  INITIAL_REVIEW
  RECHECK
  MANUAL_OVERRIDE
}

enum ReviewOutcome {
  APPROVED
  REJECTED
  MORE_INFO_REQUIRED
}

enum ContractProvider {
  DOCUSIGN
}

enum ContractStatus {
  DRAFT
  SENT
  VIEWED
  SIGNED
  DECLINED
  EXPIRED
}

enum TransportMode {
  NONE
  PUBLIC_TRANSPORT
  CAR
  BIKE
  WALK
}

enum ServiceType {
  REGULAR_CLEANING
  DEEP_CLEANING
  OFFICE_CLEANING
  AIRBNB_TURNOVER
  END_OF_TENANCY
}

enum PropertyType {
  FLAT
  HOUSE
  OFFICE
  STUDIO
  OTHER
}

enum QuoteStatus {
  DRAFT
  GENERATED
  EXPIRED
  CONVERTED
  CANCELLED
}

enum BookingStatus {
  AWAITING_PAYMENT
  PAID
  PENDING_ASSIGNMENT
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_CLEANER_FOUND
  REFUND_PENDING
  REFUNDED
}

enum BookingType {
  ONE_OFF
  RECURRING
}

enum RecurringFrequency {
  WEEKLY
  FORTNIGHTLY
  MONTHLY
}

enum PaymentProvider {
  STRIPE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum RefundType {
  FULL
  PARTIAL
}

enum RefundStatus {
  PENDING
  PROCESSED
  FAILED
  CANCELLED
}

enum JobStatus {
  CREATED
  OFFERING
  ASSIGNED
  ACCEPTED
  CANCELLED_BY_CLEANER
  CANCELLED_BY_CUSTOMER
  NO_SHOW
  NO_CLEANER_FOUND
  COMPLETED
}

enum OfferChannel {
  WHATSAPP
  SMS
  EMAIL
}

enum OfferStatus {
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
  WITHDRAWN
}

enum AssignmentStatus {
  ASSIGNED
  ACCEPTED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum ActorType {
  ADMIN
  SYSTEM
  CUSTOMER
  CLEANER
}

enum ScoreEventType {
  JOB_COMPLETED
  LATE_CANCEL
  COMPLAINT_UPHELD
  NO_SHOW
  MANUAL_ADJUSTMENT
}

enum ComplaintStatus {
  OPEN
  UNDER_REVIEW
  UPHELD
  REJECTED
  RESOLVED
}

enum ComplaintType {
  POOR_QUALITY
  LATE_ARRIVAL
  MISSED_TASKS
  INAPPROPRIATE_BEHAVIOUR
  DAMAGE_CLAIM
  NO_SHOW
  OTHER
}

enum NotificationRelatedType {
  APPLICATION
  BOOKING
  JOB
  COMPLAINT
  REFUND
  CONTRACT
}

enum RecipientType {
  CUSTOMER
  CLEANER
  ADMIN
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
  DELIVERED
  READ
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model AdminUser {
  id           String                      @id @default(cuid())
  fullName     String
  email        String                      @unique
  phone        String?
  passwordHash String?
  role         AdminRole
  status       RecordStatus                @default(ACTIVE)
  lastLoginAt  DateTime?
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt
  reviewedDocs CleanerDocument[]
  reviews      CleanerVerificationReview[]
  refunds      Refund[]
  complaints   Complaint[]
}

model Customer {
  id               String           @id @default(cuid())
  firstName        String
  lastName         String
  email            String           @unique
  phone            String
  marketingConsent Boolean          @default(false)
  status           RecordStatus     @default(ACTIVE)
  stripeCustomerId String?          @unique
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  addresses        CustomerAddress[]
  quotes           Quote[]
  bookings         Booking[]
  payments         Payment[]
  complaints       Complaint[]
}

model CustomerAddress {
  id           String    @id @default(cuid())
  customerId   String
  label        String?
  addressLine1 String
  addressLine2 String?
  city         String
  postcode     String
  county       String?
  entryNotes   String?
  parkingNotes String?
  hasPets      Boolean   @default(false)
  isDefault    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  customer     Customer  @relation(fields: [customerId], references: [id])
  bookings     Booking[]

  @@index([customerId])
  @@index([postcode])
}

model Cleaner {
  id                    String                       @id @default(cuid())
  publicId              String                       @unique @default(cuid())
  firstName             String
  lastName              String
  email                 String                       @unique
  phone                 String                       @unique
  dateOfBirth           DateTime?
  profilePhotoPath      String?
  addressLine1          String?
  addressLine2          String?
  city                  String?
  postcode              String?
  nationality           String?
  rightToWorkStatus     String?
  dbsStatus             String?
  utrNumber             String?
  niNumber              String?
  hasOwnSupplies        Boolean                      @default(false)
  hasOwnEquipment       Boolean                      @default(false)
  transportMode         TransportMode                @default(NONE)
  bio                   String?
  spokenLanguages       String[]
  canWorkWeekends       Boolean                      @default(false)
  canWorkEvenings       Boolean                      @default(false)
  wantsRegularJobs      Boolean                      @default(true)
  wantsOneOffJobs       Boolean                      @default(true)
  isEmailVerified       Boolean                      @default(false)
  isPhoneVerified       Boolean                      @default(false)
  status                CleanerStatus                @default(NEW)
  scoreCurrent          Int                          @default(100)
  scoreRankBucket       String?
  acceptedTermsAt       DateTime?
  activatedAt           DateTime?
  suspendedAt           DateTime?
  lastJobOfferedAt      DateTime?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  applications          CleanerApplication[]
  documents             CleanerDocument[]
  reviews               CleanerVerificationReview[]
  availabilityRules     CleanerAvailabilityRule[]
  unavailableDates      CleanerUnavailableDate[]
  serviceAreas          CleanerServiceArea[]
  contracts             CleanerContract[]
  scoreSummary          CleanerScore?
  scoreLogs             CleanerScoreLog[]
  assignedJobs          Job[]                        @relation("AssignedCleaner")
  jobOffers             JobOffer[]
  jobAssignments        JobAssignment[]
  jobCancellations      JobCancellation[]
  complaints            Complaint[]

  @@index([status])
  @@index([postcode])
  @@index([scoreCurrent])
}

model CleanerApplication {
  id                 String             @id @default(cuid())
  cleanerId          String
  source             ApplicationSource
  sourceReference    String?
  yearsExperience    Int?
  cleaningTypes      ServiceType[]
  dbsWillingToPay    Boolean            @default(false)
  notesFromApplicant String?
  applicationStatus  ApplicationStatus  @default(SUBMITTED)
  submittedAt        DateTime?
  reviewStartedAt    DateTime?
  reviewCompletedAt  DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  cleaner            Cleaner            @relation(fields: [cleanerId], references: [id])

  @@index([cleanerId])
  @@index([source])
  @@index([applicationStatus])
}

model CleanerDocument {
  id                 String              @id @default(cuid())
  cleanerId          String
  documentType       DocumentType
  filePath           String
  fileName           String
  fileMimeType       String?
  fileSize           Int?
  verificationStatus VerificationStatus  @default(PENDING)
  expiryDate         DateTime?
  uploadedAt         DateTime            @default(now())
  reviewedAt         DateTime?
  reviewedByAdminId  String?
  reviewNotes        String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  cleaner            Cleaner             @relation(fields: [cleanerId], references: [id])
  reviewedByAdmin    AdminUser?          @relation(fields: [reviewedByAdminId], references: [id])

  @@index([cleanerId])
  @@index([documentType])
  @@index([verificationStatus])
}

model CleanerVerificationReview {
  id              String         @id @default(cuid())
  cleanerId       String
  adminUserId     String
  reviewType      ReviewType
  idVerified      Boolean        @default(false)
  rtwVerified     Boolean        @default(false)
  addressVerified Boolean        @default(false)
  cvReviewed      Boolean        @default(false)
  photoReviewed   Boolean        @default(false)
  dbsReviewed     Boolean        @default(false)
  outcome         ReviewOutcome
  notes           String?
  createdAt       DateTime       @default(now())
  cleaner         Cleaner        @relation(fields: [cleanerId], references: [id])
  adminUser       AdminUser      @relation(fields: [adminUserId], references: [id])

  @@index([cleanerId])
  @@index([adminUserId])
}

model CleanerContract {
  id                 String           @id @default(cuid())
  cleanerId          String
  contractVersion    String
  provider           ContractProvider
  providerEnvelopeId String?          @unique
  status             ContractStatus   @default(DRAFT)
  signedFilePath     String?
  sentAt             DateTime?
  viewedAt           DateTime?
  signedAt           DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  cleaner            Cleaner          @relation(fields: [cleanerId], references: [id])

  @@index([cleanerId])
  @@index([status])
}

model CleanerAvailabilityRule {
  id          String    @id @default(cuid())
  cleanerId   String
  dayOfWeek   Int
  startTime   String
  endTime     String
  isAvailable Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  cleaner     Cleaner   @relation(fields: [cleanerId], references: [id])

  @@index([cleanerId])
  @@index([dayOfWeek])
}

model CleanerUnavailableDate {
  id        String   @id @default(cuid())
  cleanerId String
  date      DateTime
  startTime String?
  endTime   String?
  reason    String?
  createdAt DateTime @default(now())
  cleaner   Cleaner  @relation(fields: [cleanerId], references: [id])

  @@index([cleanerId])
  @@index([date])
}

model CleanerServiceArea {
  id             String   @id @default(cuid())
  cleanerId      String
  postcodePrefix String
  radiusMiles    Float?
  isPrimaryArea  Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  cleaner        Cleaner  @relation(fields: [cleanerId], references: [id])

  @@index([cleanerId])
  @@index([postcodePrefix])
}

model CleanerScore {
  id                       String   @id @default(cuid())
  cleanerId                String   @unique
  currentScore             Int      @default(100)
  lifetimeCompletedJobs    Int      @default(0)
  lifetimeCancelledJobs    Int      @default(0)
  lifetimeNoShows          Int      @default(0)
  lifetimeUpheldComplaints Int      @default(0)
  lastScoreChangeAt        DateTime?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  cleaner                  Cleaner  @relation(fields: [cleanerId], references: [id])
}

model CleanerScoreLog {
  id            String         @id @default(cuid())
  cleanerId     String
  bookingId     String?
  jobId         String?
  eventType     ScoreEventType
  scoreDelta    Int
  scoreBefore   Int
  scoreAfter    Int
  reason        String?
  createdByType ActorType
  createdById   String?
  createdAt     DateTime       @default(now())
  cleaner       Cleaner        @relation(fields: [cleanerId], references: [id])
  booking       Booking?       @relation(fields: [bookingId], references: [id])
  job           Job?           @relation(fields: [jobId], references: [id])

  @@index([cleanerId])
  @@index([bookingId])
  @@index([jobId])
  @@index([eventType])
}

model Quote {
  id                       String        @id @default(cuid())
  publicReference          String        @unique @default(cuid())
  customerId               String?
  addressLine1             String
  addressLine2             String?
  city                     String
  postcode                 String
  propertyType             PropertyType
  bedroomCount             Int?
  bathroomCount            Int?
  estimatedHours           Decimal       @db.Decimal(5, 2)
  serviceType              ServiceType
  customerProvidesSupplies Boolean       @default(false)
  preferredDate            DateTime?
  preferredTime            String?
  bookingType              BookingType   @default(ONE_OFF)
  recurringFrequency       RecurringFrequency?
  additionalNotes          String?
  baseAmount               Decimal       @db.Decimal(10, 2)
  addonsAmount             Decimal       @db.Decimal(10, 2)
  surchargeAmount          Decimal       @db.Decimal(10, 2)
  discountAmount           Decimal       @db.Decimal(10, 2) @default(0)
  totalAmount              Decimal       @db.Decimal(10, 2)
  quoteStatus              QuoteStatus   @default(GENERATED)
  expiresAt                DateTime?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  customer                 Customer?     @relation(fields: [customerId], references: [id])
  addons                   QuoteAddon[]
  bookings                 Booking[]

  @@index([customerId])
  @@index([postcode])
  @@index([quoteStatus])
}

model QuoteAddon {
  id         String   @id @default(cuid())
  quoteId    String
  addonCode  String
  addonName  String
  quantity   Int      @default(1)
  unitPrice  Decimal  @db.Decimal(10, 2)
  totalPrice Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  quote      Quote    @relation(fields: [quoteId], references: [id])

  @@index([quoteId])
}

model Booking {
  id                       String              @id @default(cuid())
  publicReference          String              @unique @default(cuid())
  quoteId                  String?
  customerId               String
  customerAddressId        String?
  parentBookingId          String?
  serviceAddressLine1      String
  serviceAddressLine2      String?
  serviceCity              String
  servicePostcode          String
  propertyType             PropertyType
  bedroomCount             Int?
  bathroomCount            Int?
  serviceType              ServiceType
  bookingType              BookingType         @default(ONE_OFF)
  recurringFrequency       RecurringFrequency?
  scheduledDate            DateTime
  scheduledStartTime       String
  scheduledEndTime         String?
  durationHours            Decimal             @db.Decimal(5, 2)
  customerProvidesSupplies Boolean             @default(false)
  additionalNotes          String?
  internalNotes            String?
  bookingStatus            BookingStatus       @default(AWAITING_PAYMENT)
  rescheduleCount          Int                 @default(0)
  cancelledByType          ActorType?
  cancelledReason          String?
  totalAmount              Decimal             @db.Decimal(10, 2)
  cleanerPayoutAmount      Decimal?            @db.Decimal(10, 2)
  platformMarginAmount     Decimal?            @db.Decimal(10, 2)
  isCustomerNotified       Boolean             @default(false)
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  quote                    Quote?              @relation(fields: [quoteId], references: [id])
  customer                 Customer            @relation(fields: [customerId], references: [id])
  customerAddress          CustomerAddress?    @relation(fields: [customerAddressId], references: [id])
  parentBooking            Booking?            @relation("BookingReschedule", fields: [parentBookingId], references: [id])
  rescheduledBookings      Booking[]           @relation("BookingReschedule")
  addons                   BookingAddon[]
  payments                 Payment[]
  refunds                  Refund[]
  jobs                     Job[]
  complaints               Complaint[]
  scoreLogs                CleanerScoreLog[]
  cancellations            JobCancellation[]

  @@index([customerId])
  @@index([quoteId])
  @@index([bookingStatus])
  @@index([scheduledDate])
  @@index([servicePostcode])
  @@index([parentBookingId])
}

model BookingAddon {
  id         String   @id @default(cuid())
  bookingId  String
  addonCode  String
  addonName  String
  quantity   Int      @default(1)
  unitPrice  Decimal  @db.Decimal(10, 2)
  totalPrice Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  booking    Booking  @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
}

model Payment {
  id                      String          @id @default(cuid())
  bookingId               String
  customerId              String
  provider                PaymentProvider
  providerPaymentIntentId String?         @unique
  providerChargeId        String?         @unique
  currency                String          @default("GBP")
  amount                  Decimal         @db.Decimal(10, 2)
  feeAmount               Decimal?        @db.Decimal(10, 2)
  netAmount               Decimal?        @db.Decimal(10, 2)
  paymentStatus           PaymentStatus   @default(PENDING)
  paidAt                  DateTime?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  booking                 Booking         @relation(fields: [bookingId], references: [id])
  customer                Customer        @relation(fields: [customerId], references: [id])
  refunds                 Refund[]

  @@index([bookingId])
  @@index([customerId])
  @@index([paymentStatus])
}

model Refund {
  id                 String       @id @default(cuid())
  paymentId          String
  bookingId          String
  providerRefundId   String?      @unique
  refundReason       String?
  refundType         RefundType
  amount             Decimal      @db.Decimal(10, 2)
  status             RefundStatus @default(PENDING)
  processedByAdminId String?
  processedAt        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  payment            Payment      @relation(fields: [paymentId], references: [id])
  booking            Booking      @relation(fields: [bookingId], references: [id])
  processedByAdmin   AdminUser?   @relation(fields: [processedByAdminId], references: [id])

  @@index([paymentId])
  @@index([bookingId])
  @@index([status])
}

model Job {
  id                   String             @id @default(cuid())
  publicReference      String             @unique @default(cuid())
  bookingId            String
  jobStatus            JobStatus          @default(CREATED)
  dispatchRound        Int                @default(1)
  assignmentDeadlineAt DateTime?
  assignedCleanerId    String?
  acceptedAt           DateTime?
  startedAt            DateTime?
  completedAt          DateTime?
  customerNotifiedAt   DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  booking              Booking            @relation(fields: [bookingId], references: [id])
  assignedCleaner      Cleaner?           @relation("AssignedCleaner", fields: [assignedCleanerId], references: [id])
  offers               JobOffer[]
  assignments          JobAssignment[]
  cancellations        JobCancellation[]
  complaints           Complaint[]
  scoreLogs            CleanerScoreLog[]

  @@index([bookingId])
  @@index([jobStatus])
  @@index([assignedCleanerId])
}

model JobOffer {
  id                 String        @id @default(cuid())
  jobId              String
  cleanerId          String
  offerChannel       OfferChannel
  offerStatus        OfferStatus   @default(SENT)
  responseDeadlineAt DateTime?
  sentAt             DateTime      @default(now())
  viewedAt           DateTime?
  respondedAt        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  job                Job           @relation(fields: [jobId], references: [id])
  cleaner            Cleaner       @relation(fields: [cleanerId], references: [id])

  @@index([jobId])
  @@index([cleanerId])
  @@index([offerStatus])
}

model JobAssignment {
  id               String           @id @default(cuid())
  jobId            String
  bookingId        String
  cleanerId        String
  assignmentStatus AssignmentStatus @default(ASSIGNED)
  assignedAt       DateTime         @default(now())
  acceptedAt       DateTime?
  cancelledAt      DateTime?
  completedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  job              Job              @relation(fields: [jobId], references: [id])
  booking          Booking          @relation(fields: [bookingId], references: [id])
  cleaner          Cleaner          @relation(fields: [cleanerId], references: [id])

  @@index([jobId])
  @@index([bookingId])
  @@index([cleanerId])
  @@index([assignmentStatus])
}

model JobCancellation {
  id                  String    @id @default(cuid())
  jobId               String
  bookingId           String
  cleanerId           String?
  cancelledByType     ActorType
  hoursBeforeStart    Decimal?  @db.Decimal(6, 2)
  within48Hours       Boolean   @default(false)
  reason              String?
  scorePenaltyApplied Int?
  adminNotifiedEmail  Boolean   @default(false)
  adminNotifiedSms    Boolean   @default(false)
  customerNotified    Boolean   @default(false)
  createdAt           DateTime  @default(now())
  job                 Job       @relation(fields: [jobId], references: [id])
  booking             Booking   @relation(fields: [bookingId], references: [id])
  cleaner             Cleaner?  @relation(fields: [cleanerId], references: [id])

  @@index([jobId])
  @@index([bookingId])
  @@index([cleanerId])
}

model Complaint {
  id                String           @id @default(cuid())
  bookingId         String
  jobId             String?
  customerId        String
  cleanerId         String?
  complaintType     ComplaintType
  description       String
  attachmentPath    String?
  status            ComplaintStatus  @default(OPEN)
  refundAmount      Decimal?         @db.Decimal(10, 2)
  scorePenalty      Int?
  reviewedByAdminId String?
  reviewedAt        DateTime?
  resolutionNotes   String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  booking           Booking          @relation(fields: [bookingId], references: [id])
  job               Job?             @relation(fields: [jobId], references: [id])
  customer          Customer         @relation(fields: [customerId], references: [id])
  cleaner           Cleaner?         @relation(fields: [cleanerId], references: [id])
  reviewedByAdmin   AdminUser?       @relation(fields: [reviewedByAdminId], references: [id])

  @@index([bookingId])
  @@index([jobId])
  @@index([customerId])
  @@index([cleanerId])
  @@index([status])
}

model Notification {
  id            String                  @id @default(cuid())
  relatedType   NotificationRelatedType
  relatedId     String
  recipientType RecipientType
  recipientId   String
  channel       NotificationChannel
  templateCode  String
  status        NotificationStatus      @default(QUEUED)
  subject       String?
  bodyPreview   String?
  scheduledAt   DateTime?
  sentAt        DateTime?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  logs          NotificationLog[]

  @@index([relatedType, relatedId])
  @@index([recipientType, recipientId])
  @@index([channel])
  @@index([status])
}

model NotificationLog {
  id                String        @id @default(cuid())
  notificationId    String
  providerMessageId String?
  providerName      String?
  providerStatus    String?
  errorMessage      String?
  createdAt         DateTime      @default(now())
  notification      Notification  @relation(fields: [notificationId], references: [id])

  @@index([notificationId])
}

model AuditLog {
  id         String    @id @default(cuid())
  actorType  ActorType
  actorId    String?
  actionType String
  entityType String
  entityId   String
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())

  @@index([actorType, actorId])
  @@index([entityType, entityId])
  @@index([actionType])
}

model ServicePage {
  id              String        @id @default(cuid())
  slug            String        @unique
  title           String
  metaTitle       String?
  metaDescription String?
  heroHeading     String?
  heroSubheading  String?
  contentBlocks   Json?
  faqBlocks       Json?
  status          ContentStatus @default(DRAFT)
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model SeoLandingPage {
  id              String        @id @default(cuid())
  slug            String        @unique
  locationName    String
  serviceName     String
  metaTitle       String?
  metaDescription String?
  headline        String?
  bodyContent     String?
  faqContent      Json?
  canonicalUrl    String?
  status          ContentStatus @default(DRAFT)
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([locationName])
  @@index([serviceName])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  SUPER_ADMIN
  OPS_ADMIN
  REVIEWER
  SUPPORT
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum CleanerStatus {
  NEW
  PENDING_DOCS
  UNDER_REVIEW
  APPROVED
  CONTRACT_SENT
  ACTIVE
  SUSPENDED
  REJECTED
}

enum ApplicationSource {
  INDEED
  WEBSITE
  REFERRAL
  FACEBOOK
  OTHER
}

enum ApplicationStatus {
  SUBMITTED
  PENDING_DOCS
  UNDER_REVIEW
  APPROVED
  REJECTED
  MORE_INFO_REQUIRED
}

enum DocumentType {
  ID
  CV
  PHOTO
  RIGHT_TO_WORK
  ADDRESS_PROOF
  DBS
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_REUPLOAD
}

enum ReviewType {
  INITIAL_REVIEW
  RECHECK
  MANUAL_OVERRIDE
}

enum ReviewOutcome {
  APPROVED
  REJECTED
  MORE_INFO_REQUIRED
}

enum ContractProvider {
  DOCUSIGN
}

enum ContractStatus {
  DRAFT
  SENT
  VIEWED
  SIGNED
  DECLINED
  EXPIRED
}

enum TransportMode {
  NONE
  PUBLIC_TRANSPORT
  CAR
  BIKE
  WALK
}

enum QuoteStatus {
  DRAFT
  GENERATED
  EXPIRED
  CONVERTED
  CANCELLED
}

enum ServiceType {
  REGULAR_CLEANING
  DEEP_CLEANING
  OFFICE_CLEANING
  AIRBNB_TURNOVER
  END_OF_TENANCY
  PEST_CONTROL
  HANDYMAN
  FURNITURE_ASSEMBLY
  WASTE_REMOVAL
  GARDEN_MAINTENANCE
}

enum PropertyType {
  FLAT
  HOUSE
  OFFICE
  STUDIO
  OTHER
}

enum BookingStatus {
  AWAITING_PAYMENT
  PAID
  PENDING_ASSIGNMENT
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_CLEANER_FOUND
  REFUND_PENDING
  REFUNDED
}

enum PaymentProvider {
  STRIPE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum RefundType {
  FULL
  PARTIAL
}

enum RefundStatus {
  PENDING
  PROCESSED
  FAILED
  CANCELLED
}

enum JobStatus {
  CREATED
  OFFERING
  ASSIGNED
  ACCEPTED
  CANCELLED_BY_CLEANER
  CANCELLED_BY_CUSTOMER
  NO_SHOW
  NO_CLEANER_FOUND
  COMPLETED
}

enum OfferChannel {
  WHATSAPP
  SMS
  EMAIL
}

enum OfferStatus {
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
  WITHDRAWN
}

enum AssignmentStatus {
  ASSIGNED
  ACCEPTED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum ActorType {
  ADMIN
  SYSTEM
  CUSTOMER
  CLEANER
  PROVIDER
}

enum ScoreEventType {
  JOB_COMPLETED
  LATE_CANCEL
  COMPLAINT_UPHELD
  NO_SHOW
  MANUAL_ADJUSTMENT
}

enum ComplaintStatus {
  OPEN
  UNDER_REVIEW
  UPHELD
  REJECTED
  RESOLVED
}

enum ComplaintType {
  POOR_QUALITY
  LATE_ARRIVAL
  MISSED_TASKS
  INAPPROPRIATE_BEHAVIOUR
  DAMAGE_CLAIM
  NO_SHOW
  OTHER
}

enum NotificationRelatedType {
  APPLICATION
  BOOKING
  JOB
  COMPLAINT
  REFUND
}

enum RecipientType {
  CUSTOMER
  CLEANER
  ADMIN
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
  DELIVERED
  READ
}

enum PublicQuoteState {
  DRAFT
  PRICED
  MANUAL_REVIEW_REQUIRED
  REQUEST_SUBMITTED
  BOOKING_CREATED
  EXPIRED
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model AdminUser {
  id             String                      @id @default(cuid())
  fullName       String
  email          String                      @unique
  phone          String?
  passwordHash   String?
  role           AdminRole
  status         RecordStatus                @default(ACTIVE)
  lastLoginAt    DateTime?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  reviewedDocs   CleanerDocument[]
  reviews        CleanerVerificationReview[]
  refunds        Refund[]
  complaints     Complaint[]
}

model Customer {
  id               String      @id @default(cuid())
  firstName        String
  lastName         String
  email            String      @unique
  phone            String
  marketingConsent Boolean     @default(false)
  status           RecordStatus @default(ACTIVE)
  stripeCustomerId String?     @unique
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  addresses        CustomerAddress[]
  quotes           Quote[]
  bookings         Booking[]
  payments         Payment[]
  complaints       Complaint[]
}

model CustomerAddress {
  id            String    @id @default(cuid())
  customerId    String
  label         String?
  addressLine1  String
  addressLine2  String?
  city          String
  postcode      String
  county        String?
  entryNotes    String?
  parkingNotes  String?
  hasPets       Boolean   @default(false)
  isDefault     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  customer      Customer  @relation(fields: [customerId], references: [id])
  bookings      Booking[]

  @@index([customerId])
  @@index([postcode])
}

model Cleaner {
  id                   String                       @id @default(cuid())
  firstName            String
  lastName             String
  email                String                       @unique
  phone                String                       @unique
  dateOfBirth          DateTime?
  profilePhotoPath     String?
  addressLine1         String?
  addressLine2         String?
  city                 String?
  postcode             String?
  nationality          String?
  rightToWorkStatus    String?
  dbsStatus            String?
  utrNumber            String?
  niNumber             String?
  hasOwnSupplies       Boolean                      @default(false)
  hasOwnEquipment      Boolean                      @default(false)
  transportMode        TransportMode                @default(NONE)
  bio                  String?
  spokenLanguages      String[]
  status               CleanerStatus                @default(NEW)
  scoreCurrent         Int                          @default(100)
  scoreRankBucket      String?
  acceptedTermsAt      DateTime?
  activatedAt          DateTime?
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt
  applications         CleanerApplication[]
  documents            CleanerDocument[]
  reviews              CleanerVerificationReview[]
  availabilityRules    CleanerAvailabilityRule[]
  unavailableDates     CleanerUnavailableDate[]
  serviceAreas         CleanerServiceArea[]
  contracts            CleanerContract[]
  scoreSummary         CleanerScore?
  scoreLogs            CleanerScoreLog[]
  assignedJobs         Job[]                        @relation("AssignedCleaner")
  jobOffers            JobOffer[]
  jobAssignments       JobAssignment[]
  jobCancellations     JobCancellation[]
  complaints           Complaint[]

  @@index([status])
  @@index([postcode])
  @@index([scoreCurrent])
}

model CleanerApplication {
  id                String             @id @default(cuid())
  cleanerId         String
  source            ApplicationSource
  sourceReference   String?
  yearsExperience   Int?
  cleaningTypes     ServiceType[]
  canWorkWeekends   Boolean            @default(false)
  canWorkEvenings   Boolean            @default(false)
  wantsRegularJobs  Boolean            @default(true)
  wantsOneOffJobs   Boolean            @default(true)
  dbsWillingToPay   Boolean            @default(false)
  notesFromApplicant String?
  applicationStatus ApplicationStatus  @default(SUBMITTED)
  submittedAt       DateTime?
  reviewStartedAt   DateTime?
  reviewCompletedAt DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  cleaner           Cleaner            @relation(fields: [cleanerId], references: [id])

  @@index([cleanerId])
  @@index([source])
  @@index([applicationStatus])
}

model CleanerDocument {
  id                 String              @id @default(cuid())
  cleanerId          String
  documentType       DocumentType
  filePath           String
  fileName           String
  fileMimeType       String?
  fileSize           Int?
  verificationStatus VerificationStatus  @default(PENDING)
  expiryDate         DateTime?
  uploadedAt         DateTime            @default(now())
  reviewedAt         DateTime?
  reviewedByAdminId  String?
  reviewNotes        String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  cleaner            Cleaner             @relation(fields: [cleanerId], references: [id])
  reviewedByAdmin    AdminUser?          @relation(fields: [reviewedByAdminId], references: [id])

  @@index([cleanerId])
  @@index([documentType])
  @@index([verificationStatus])
}

model CleanerVerificationReview {
  id              String         @id @default(cuid())
  cleanerId       String
  adminUserId     String
  reviewType      ReviewType
  idVerified      Boolean        @default(false)
  rtwVerified     Boolean        @default(false)
  addressVerified Boolean        @default(false)
  cvReviewed      Boolean        @default(false)
  photoReviewed   Boolean        @default(false)
  dbsReviewed     Boolean        @default(false)
  outcome         ReviewOutcome
  notes           String?
  createdAt       DateTime       @default(now())
  cleaner         Cleaner        @relation(fields: [cleanerId], references: [id])
  adminUser       AdminUser      @relation(fields: [adminUserId], references: [id])

  @@index([cleanerId])
  @@index([adminUserId])
}

model CleanerContract {
  id                 String           @id @default(cuid())
  cleanerId          String
  contractVersion    String
  provider           ContractProvider
  providerEnvelopeId String?
  status             ContractStatus   @default(DRAFT)
  signedFilePath     String?
  sentAt             DateTime?
  signedAt           DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  cleaner            Cleaner          @relation(fields: [cleanerId], references: [id])

  @@index([cleanerId])
  @@index([status])
}

model CleanerAvailabilityRule {
  id          String    @id @default(cuid())
  cleanerId   String
  dayOfWeek   Int
  startTime   String
  endTime     String
  isAvailable Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  cleaner     Cleaner   @relation(fields: [cleanerId], references: [id])

  @@index([cleanerId])
  @@index([dayOfWeek])
}

model CleanerUnavailableDate {
  id         String    @id @default(cuid())
  cleanerId  String
  date       DateTime
  startTime  String?
  endTime    String?
  reason     String?
  createdAt  DateTime  @default(now())
  cleaner    Cleaner   @relation(fields: [cleanerId], references: [id])

  @@index([cleanerId])
  @@index([date])
}

model CleanerServiceArea {
  id             String    @id @default(cuid())
  cleanerId      String
  postcodePrefix String
  radiusMiles    Float?
  isPrimaryArea  Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  cleaner        Cleaner   @relation(fields: [cleanerId], references: [id])

  @@index([cleanerId])
  @@index([postcodePrefix])
}

model CleanerScore {
  id                        String    @id @default(cuid())
  cleanerId                 String    @unique
  currentScore              Int       @default(100)
  lifetimeCompletedJobs     Int       @default(0)
  lifetimeCancelledJobs     Int       @default(0)
  lifetimeNoShows           Int       @default(0)
  lifetimeUpheldComplaints  Int       @default(0)
  lastScoreChangeAt         DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  cleaner                   Cleaner   @relation(fields: [cleanerId], references: [id])
}

model CleanerScoreLog {
  id             String          @id @default(cuid())
  cleanerId      String
  bookingId      String?
  jobId          String?
  eventType      ScoreEventType
  scoreDelta     Int
  scoreBefore    Int
  scoreAfter     Int
  reason         String?
  createdByType  ActorType
  createdById    String?
  createdAt      DateTime        @default(now())
  cleaner        Cleaner         @relation(fields: [cleanerId], references: [id])
  booking        Booking?        @relation(fields: [bookingId], references: [id])
  job            Job?            @relation(fields: [jobId], references: [id])

  @@index([cleanerId])
  @@index([bookingId])
  @@index([jobId])
  @@index([eventType])
}

model Quote {
  id                        String        @id @default(cuid())
  customerId                String?
  addressLine1              String
  addressLine2              String?
  city                      String
  postcode                  String
  propertyType              PropertyType
  bedroomCount              Int?
  bathroomCount             Int?
  estimatedHours            Decimal       @db.Decimal(5, 2)
  serviceType               ServiceType
  customerProvidesSupplies  Boolean       @default(false)
  preferredDate             DateTime?
  preferredTime             String?
  isRecurring               Boolean       @default(false)
  recurringFrequency        String?
  additionalNotes           String?
  baseAmount                Decimal       @db.Decimal(10, 2)
  addonsAmount              Decimal       @db.Decimal(10, 2)
  surchargeAmount           Decimal       @db.Decimal(10, 2)
  discountAmount            Decimal       @db.Decimal(10, 2) @default(0)
  totalAmount               Decimal       @db.Decimal(10, 2)
  quoteStatus               QuoteStatus   @default(GENERATED)
  expiresAt                 DateTime?
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt
  customer                  Customer?     @relation(fields: [customerId], references: [id])
  addons                    QuoteAddon[]
  bookings                  Booking[]

  @@index([customerId])
  @@index([postcode])
  @@index([quoteStatus])
}

model QuoteAddon {
  id         String   @id @default(cuid())
  quoteId    String
  addonCode  String
  addonName  String
  quantity   Int      @default(1)
  unitPrice  Decimal  @db.Decimal(10, 2)
  totalPrice Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  quote      Quote    @relation(fields: [quoteId], references: [id])

  @@index([quoteId])
}

model Booking {
  id                       String             @id @default(cuid())
  quoteId                  String?
  customerId               String
  customerAddressId        String?
  providerCompanyId        String?
  serviceAddressLine1      String
  serviceAddressLine2      String?
  serviceCity              String
  servicePostcode          String
  propertyType             PropertyType
  bedroomCount             Int?
  bathroomCount            Int?
  serviceType              ServiceType
  scheduledDate            DateTime
  scheduledStartTime       String
  scheduledEndTime         String?
  durationHours            Decimal            @db.Decimal(5, 2)
  customerProvidesSupplies Boolean            @default(false)
  additionalNotes          String?
  bookingStatus            BookingStatus      @default(AWAITING_PAYMENT)
  rescheduleCount          Int                @default(0)
  cancelledByType          ActorType?
  cancelledReason          String?
  totalAmount              Decimal            @db.Decimal(10, 2)
  cleanerPayoutAmount      Decimal?           @db.Decimal(10, 2)
  platformMarginAmount     Decimal?           @db.Decimal(10, 2)
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  quote                    Quote?             @relation(fields: [quoteId], references: [id])
  customer                 Customer           @relation(fields: [customerId], references: [id])
  customerAddress          CustomerAddress?   @relation(fields: [customerAddressId], references: [id])
  marketplaceProviderCompany ProviderCompany? @relation("MarketplaceProviderCompany", fields: [providerCompanyId], references: [id])
  quoteRequest             QuoteRequest?
  addons                   BookingAddon[]
  payments                 Payment[]
  refunds                  Refund[]
  jobs                     Job[]
  jobAssignments           JobAssignment[]
  complaints               Complaint[]
  scoreLogs                CleanerScoreLog[]
  cancellations            JobCancellation[]
  priceSnapshot            BookingPriceSnapshot?
  paymentRecords           PaymentRecord[]
  refundRecords            RefundRecord[]
  disputeRecords           DisputeRecord[]
  payoutRecords            PayoutRecord[]
  ledgerEntries            LedgerEntry[]
  invoiceRecords           InvoiceRecord[]
  notificationLogsV2       NotificationLogV2[]

  @@index([customerId])
  @@index([quoteId])
  @@index([bookingStatus])
  @@index([scheduledDate])
  @@index([servicePostcode])
  @@index([providerCompanyId])
}

model QuoteRequest {
  id                        String           @id @default(cuid())
  reference                 String           @unique
  customerName              String
  customerEmail             String
  customerPhone             String
  postcode                  String
  postcodePrefix            String
  addressLine1              String
  addressLine2              String?
  city                      String
  categoryKey               String
  serviceKey                String
  providerCompanyId         String?
  bookingId                 String?          @unique
  state                     PublicQuoteState @default(DRAFT)
  quoteRequired             Boolean          @default(false)
  scheduledDate             DateTime?
  scheduledTimeLabel        String?
  inputJson                 Json?
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt

  providerCompany           ProviderCompany? @relation(fields: [providerCompanyId], references: [id])
  booking                   Booking?         @relation(fields: [bookingId], references: [id])
  priceSnapshot             QuotePriceSnapshot?

  @@index([postcode])
  @@index([postcodePrefix])
  @@index([categoryKey])
  @@index([serviceKey])
  @@index([state])
}

model QuotePriceSnapshot {
  id                               String       @id @default(cuid())
  quoteRequestId                   String       @unique
  providerCompanyId                String?
  pricingRuleId                    String?
  providerBasePrice                Decimal      @db.Decimal(10, 2)
  bookingFee                       Decimal      @db.Decimal(10, 2)
  commissionAmount                 Decimal      @db.Decimal(10, 2)
  postcodeSurcharge                Decimal      @db.Decimal(10, 2)
  totalCustomerPay                 Decimal      @db.Decimal(10, 2)
  expectedProviderPayoutBeforeFees Decimal      @db.Decimal(10, 2)
  quantity                         Int          @default(1)
  estimatedHours                   Decimal      @db.Decimal(5, 2)
  sameDay                          Boolean      @default(false)
  weekend                          Boolean      @default(false)
  quoteRequired                    Boolean      @default(false)
  inputJson                        Json?
  createdAt                        DateTime     @default(now())

  quoteRequest                     QuoteRequest @relation(fields: [quoteRequestId], references: [id])
}

model BookingAddon {
  id         String   @id @default(cuid())
  bookingId  String
  addonCode  String
  addonName  String
  quantity   Int      @default(1)
  unitPrice  Decimal  @db.Decimal(10, 2)
  totalPrice Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  booking    Booking  @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
}

model Payment {
  id                      String          @id @default(cuid())
  bookingId               String
  customerId              String
  provider                PaymentProvider
  providerPaymentIntentId String?         @unique
  providerChargeId        String?         @unique
  currency                String          @default("GBP")
  amount                  Decimal         @db.Decimal(10, 2)
  feeAmount               Decimal?        @db.Decimal(10, 2)
  netAmount               Decimal?        @db.Decimal(10, 2)
  paymentStatus           PaymentStatus   @default(PENDING)
  paidAt                  DateTime?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  booking                 Booking         @relation(fields: [bookingId], references: [id])
  customer                Customer        @relation(fields: [customerId], references: [id])
  refunds                 Refund[]

  @@index([bookingId])
  @@index([customerId])
  @@index([paymentStatus])
}

model Refund {
  id                 String       @id @default(cuid())
  paymentId          String
  bookingId          String
  providerRefundId   String?      @unique
  refundReason       String?
  refundType         RefundType
  amount             Decimal      @db.Decimal(10, 2)
  status             RefundStatus @default(PENDING)
  processedByAdminId String?
  processedAt        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  payment            Payment      @relation(fields: [paymentId], references: [id])
  booking            Booking      @relation(fields: [bookingId], references: [id])
  processedByAdmin   AdminUser?   @relation(fields: [processedByAdminId], references: [id])

  @@index([paymentId])
  @@index([bookingId])
  @@index([status])
}

model Job {
  id                   String             @id @default(cuid())
  bookingId            String
  jobStatus            JobStatus          @default(CREATED)
  dispatchRound        Int                @default(1)
  assignmentDeadlineAt DateTime?
  assignedCleanerId    String?
  acceptedAt           DateTime?
  startedAt            DateTime?
  completedAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  booking              Booking            @relation(fields: [bookingId], references: [id])
  assignedCleaner      Cleaner?           @relation("AssignedCleaner", fields: [assignedCleanerId], references: [id])
  offers               JobOffer[]
  assignments          JobAssignment[]
  cancellations        JobCancellation[]
  complaints           Complaint[]
  scoreLogs            CleanerScoreLog[]

  @@index([bookingId])
  @@index([jobStatus])
  @@index([assignedCleanerId])
}

model JobOffer {
  id                 String        @id @default(cuid())
  jobId              String
  cleanerId          String
  offerChannel       OfferChannel
  offerStatus        OfferStatus   @default(SENT)
  responseDeadlineAt DateTime?
  sentAt             DateTime      @default(now())
  respondedAt        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  job                Job           @relation(fields: [jobId], references: [id])
  cleaner            Cleaner       @relation(fields: [cleanerId], references: [id])

  @@index([jobId])
  @@index([cleanerId])
  @@index([offerStatus])
}

model JobAssignment {
  id               String           @id @default(cuid())
  jobId            String
  bookingId        String
  cleanerId        String
  assignmentStatus AssignmentStatus @default(ASSIGNED)
  assignedAt       DateTime         @default(now())
  acceptedAt       DateTime?
  cancelledAt      DateTime?
  completedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  job              Job              @relation(fields: [jobId], references: [id])
  booking          Booking          @relation(fields: [bookingId], references: [id])
  cleaner          Cleaner          @relation(fields: [cleanerId], references: [id])

  @@index([jobId])
  @@index([bookingId])
  @@index([cleanerId])
  @@index([assignmentStatus])
}

model JobCancellation {
  id                  String    @id @default(cuid())
  jobId               String
  bookingId           String
  cleanerId           String?
  cancelledByType     ActorType
  hoursBeforeStart    Decimal?  @db.Decimal(6, 2)
  within48Hours       Boolean   @default(false)
  reason              String?
  scorePenaltyApplied Int?
  adminNotifiedEmail  Boolean   @default(false)
  adminNotifiedSms    Boolean   @default(false)
  createdAt           DateTime  @default(now())
  job                 Job       @relation(fields: [jobId], references: [id])
  booking             Booking   @relation(fields: [bookingId], references: [id])
  cleaner             Cleaner?  @relation(fields: [cleanerId], references: [id])

  @@index([jobId])
  @@index([bookingId])
  @@index([cleanerId])
}

model Complaint {
  id                String           @id @default(cuid())
  bookingId         String
  jobId             String?
  customerId        String
  cleanerId         String?
  complaintType     ComplaintType
  description       String
  attachmentPath    String?
  status            ComplaintStatus  @default(OPEN)
  refundAmount      Decimal?         @db.Decimal(10, 2)
  scorePenalty      Int?
  reviewedByAdminId String?
  reviewedAt        DateTime?
  resolutionNotes   String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  booking           Booking          @relation(fields: [bookingId], references: [id])
  job               Job?             @relation(fields: [jobId], references: [id])
  customer          Customer         @relation(fields: [customerId], references: [id])
  cleaner           Cleaner?         @relation(fields: [cleanerId], references: [id])
  reviewedByAdmin   AdminUser?       @relation(fields: [reviewedByAdminId], references: [id])

  @@index([bookingId])
  @@index([jobId])
  @@index([customerId])
  @@index([cleanerId])
  @@index([status])
}

model Notification {
  id             String                  @id @default(cuid())
  relatedType    NotificationRelatedType
  relatedId      String
  recipientType  RecipientType
  recipientId    String
  channel        NotificationChannel
  templateCode   String
  status         NotificationStatus      @default(QUEUED)
  subject        String?
  bodyPreview    String?
  scheduledAt    DateTime?
  sentAt         DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  logs           NotificationLog[]

  @@index([relatedType, relatedId])
  @@index([recipientType, recipientId])
  @@index([channel])
  @@index([status])
}

model NotificationLog {
  id                String        @id @default(cuid())
  notificationId    String
  providerMessageId String?
  providerName      String?
  providerStatus    String?
  errorMessage      String?
  createdAt         DateTime      @default(now())
  notification      Notification  @relation(fields: [notificationId], references: [id])

  @@index([notificationId])
}

model AuditLog {
  id         String    @id @default(cuid())
  actorType  ActorType
  actorId    String?
  actionType String
  entityType String
  entityId   String
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())

  @@index([actorType, actorId])
  @@index([entityType, entityId])
  @@index([actionType])
}

model ServicePage {
  id              String        @id @default(cuid())
  slug            String        @unique
  title           String
  metaTitle       String?
  metaDescription String?
  heroHeading     String?
  heroSubheading  String?
  contentBlocks   Json?
  faqBlocks       Json?
  status          ContentStatus @default(DRAFT)
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model SeoLandingPage {
  id              String        @id @default(cuid())
  slug            String        @unique
  locationName    String
  serviceName     String
  metaTitle       String?
  metaDescription String?
  headline        String?
  bodyContent     String?
  faqContent      Json?
  canonicalUrl    String?
  status          ContentStatus @default(DRAFT)
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([locationName])
  @@index([serviceName])
}

enum ProviderCompanyStatus {
  INVITED
  EMAIL_VERIFICATION_PENDING
  PASSWORD_SETUP_PENDING
  ONBOARDING_IN_PROGRESS
  SUBMITTED_FOR_REVIEW
  UNDER_REVIEW
  CHANGES_REQUESTED
  REJECTED
  APPROVED
  STRIPE_PENDING
  STRIPE_RESTRICTED
  PRICING_PENDING
  ACTIVE
  SUSPENDED
}

enum ProviderDocumentStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_RESUBMISSION
}

enum ProviderAuthTokenPurpose {
  PASSWORD_SETUP
  PASSWORD_RESET
}

enum ConnectAccountMode {
  EXPRESS
  STANDARD
  CUSTOM
}

enum ChargeModel {
  DIRECT_CHARGES
  DESTINATION_CHARGES
  SEPARATE_CHARGES_AND_TRANSFERS
}

enum InvoiceStrategy {
  PROVIDER_SERVICE_PLUS_PLATFORM_FEE_RECEIPT
  COMBINED_CUSTOMER_RECEIPT
}

enum RefundLiability {
  PROVIDER
  PLATFORM
  SHARED
}

enum DisputeCaseStatus {
  OPEN
  NEEDS_EVIDENCE
  SUBMITTED
  WON
  LOST
  CLOSED
}

enum ProviderPayoutStatus {
  PENDING
  CREATED
  PAID
  FAILED
  CANCELLED
}

enum LedgerEntryKind {
  BOOKING_CREATED
  PAYMENT_SUCCEEDED
  APPLICATION_FEE_RECOGNIZED
  REFUND_CREATED
  REFUND_SUCCEEDED
  DISPUTE_OPENED
  DISPUTE_WON
  DISPUTE_LOST
  PAYOUT_CREATED
  PAYOUT_PAID
  PAYOUT_FAILED
  MANUAL_ADJUSTMENT
}

enum WebhookProvider {
  STRIPE
}

enum WebhookProcessingStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
  IGNORED
}

model User {
  id            String           @id @default(cuid())
  email         String           @unique
  passwordHash  String?
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  roles         UserRoleAssignment[]
  providerAuthTokens ProviderAuthToken[]
  providerCompany ProviderCompany?
}

model Role {
  id          String              @id @default(cuid())
  key         String              @unique
  label       String
  createdAt   DateTime            @default(now())
  assignments UserRoleAssignment[]
}

model UserRoleAssignment {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  role      Role     @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
}

model ProviderCompany {
  id                       String                 @id @default(cuid())
  userId                   String?                @unique
  legalName                String?
  tradingName              String?
  companyNumber            String?                @unique
  registeredAddress        String?
  contactEmail             String
  phone                    String?
  vatNumber                String?
  insuranceExpiry          DateTime?
  complianceNotes          String?
  status                   ProviderCompanyStatus  @default(INVITED)
  paymentReady             Boolean                @default(false)
  stripeRequirementsJson   Json?
  emailVerifiedAt          DateTime?
  passwordSetAt            DateTime?
  onboardingSubmittedAt    DateTime?
  reviewStartedAt          DateTime?
  changesRequestedAt       DateTime?
  rejectedAt               DateTime?
  approvedAt               DateTime?
  reviewNotes              String?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  user                     User?                  @relation(fields: [userId], references: [id])
  serviceCategories        ProviderServiceCategory[]
  coverageAreas            ProviderCoverageArea[]
  documents                ProviderOnboardingDocument[]
  pricingRules             ProviderPricingRule[]
  pricingAreaOverrides     PricingAreaOverride[]
  pricingAuditLogs         PricingAuditLog[]
  authTokens               ProviderAuthToken[]
  invites                  ProviderInvite[]
  emailVerifications       ProviderEmailVerification[]
  agreements               ProviderAgreement[]
  stripeConnectedAccount   StripeConnectedAccount?
  bookingAssignments       Booking[]              @relation("MarketplaceProviderCompany")
  quoteRequests            QuoteRequest[]
  payoutRecords            PayoutRecord[]
  disputeRecords           DisputeRecord[]
  invoiceRecords           InvoiceRecord[]
  notificationLogs         NotificationLogV2[]
}

model ProviderEmailVerification {
  id                String          @id @default(cuid())
  providerCompanyId String?
  email             String
  code              String
  purpose           String
  expiresAt         DateTime
  consumedAt        DateTime?
  createdAt         DateTime        @default(now())

  providerCompany   ProviderCompany? @relation(fields: [providerCompanyId], references: [id])

  @@index([email, purpose])
}

model ProviderAuthToken {
  id                String                   @id @default(cuid())
  providerCompanyId String?
  userId            String?
  email             String
  token             String                   @unique
  purpose           ProviderAuthTokenPurpose
  expiresAt         DateTime
  consumedAt        DateTime?
  createdAt         DateTime                 @default(now())

  providerCompany   ProviderCompany?         @relation(fields: [providerCompanyId], references: [id])
  user              User?                    @relation(fields: [userId], references: [id])

  @@index([email, purpose])
}

model ProviderOnboardingDocument {
  id                String                 @id @default(cuid())
  providerCompanyId String
  documentKey       String
  label             String
  fileName          String
  storedFileName    String
  storagePath       String
  mimeType          String?
  sizeBytes         Int?
  status            ProviderDocumentStatus @default(PENDING)
  reviewNotes       String?
  uploadedAt        DateTime               @default(now())
  reviewedAt        DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  providerCompany   ProviderCompany        @relation(fields: [providerCompanyId], references: [id])

  @@index([providerCompanyId, documentKey])
  @@unique([providerCompanyId, documentKey])
}

model ProviderServiceCategory {
  id                String          @id @default(cuid())
  providerCompanyId String
  categoryKey       String
  active            Boolean         @default(true)
  providerCompany   ProviderCompany @relation(fields: [providerCompanyId], references: [id])

  @@unique([providerCompanyId, categoryKey])
}

model ProviderCoverageArea {
  id                String          @id @default(cuid())
  providerCompanyId String
  postcodePrefix    String
  categoryKey       String
  active            Boolean         @default(true)
  providerCompany   ProviderCompany @relation(fields: [providerCompanyId], references: [id])

  @@unique([postcodePrefix, categoryKey])
}

model ProviderPricingRule {
  id                  String          @id @default(cuid())
  providerCompanyId   String
  categoryKey         String
  serviceKey          String
  pricingMode         String
  flatPrice           Decimal?        @db.Decimal(10, 2)
  hourlyPrice         Decimal?        @db.Decimal(10, 2)
  minimumCharge       Decimal?        @db.Decimal(10, 2)
  travelFee           Decimal?        @db.Decimal(10, 2)
  sameDayUplift       Decimal?        @db.Decimal(10, 2)
  weekendUplift       Decimal?        @db.Decimal(10, 2)
  customQuoteRequired Boolean         @default(false)
  pricingJson         Json?
  active              Boolean         @default(true)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  providerCompany     ProviderCompany @relation(fields: [providerCompanyId], references: [id])
  auditLogs           PricingAuditLog[]

  @@unique([providerCompanyId, categoryKey, serviceKey])
}

model PricingAreaOverride {
  id                String          @id @default(cuid())
  providerCompanyId String
  categoryKey       String
  postcodePrefix    String
  surchargeAmount   Decimal         @db.Decimal(10, 2)
  bookingFeeOverride Decimal?       @db.Decimal(10, 2)
  commissionPercentOverride Decimal? @db.Decimal(10, 2)
  active            Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  providerCompany   ProviderCompany @relation(fields: [providerCompanyId], references: [id])

  @@unique([providerCompanyId, categoryKey, postcodePrefix])
}

model PricingAuditLog {
  id                String               @id @default(cuid())
  providerCompanyId String
  providerPricingRuleId String?
  actorType         ActorType
  actorId           String?
  action            String
  beforeJson        Json?
  afterJson         Json?
  createdAt         DateTime             @default(now())

  providerCompany   ProviderCompany      @relation(fields: [providerCompanyId], references: [id])
  providerPricingRule ProviderPricingRule? @relation(fields: [providerPricingRuleId], references: [id])
}

model ProviderInvite {
  id                String          @id @default(cuid())
  providerCompanyId String?
  email             String
  approvedCategoryKey String?
  approvedServiceKeysJson Json?
  token             String          @unique
  expiresAt         DateTime
  acceptedAt        DateTime?
  createdAt         DateTime        @default(now())
  providerCompany   ProviderCompany? @relation(fields: [providerCompanyId], references: [id])
}

model ProviderAgreement {
  id                String                @id @default(cuid())
  providerCompanyId String
  version           String
  status            ContractStatus        @default(DRAFT)
  documentUrl       String?
  signedAt          DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  providerCompany   ProviderCompany       @relation(fields: [providerCompanyId], references: [id])
}

model StripeConnectedAccount {
  id                   String             @id @default(cuid())
  providerCompanyId    String             @unique
  stripeAccountId      String             @unique
  mode                 ConnectAccountMode @default(EXPRESS)
  chargeModel          ChargeModel        @default(DIRECT_CHARGES)
  chargesEnabled       Boolean            @default(false)
  payoutsEnabled       Boolean            @default(false)
  detailsSubmitted     Boolean            @default(false)
  requirementsJson     Json?
  onboardingUrl        String?
  lastSyncedAt         DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  providerCompany      ProviderCompany    @relation(fields: [providerCompanyId], references: [id])
}

model BookingPriceSnapshot {
  id                         String   @id @default(cuid())
  bookingId                  String   @unique
  providerServiceAmount      Decimal  @db.Decimal(10, 2)
  platformBookingFee         Decimal  @db.Decimal(10, 2)
  platformCommissionAmount   Decimal  @db.Decimal(10, 2)
  platformMarkupAmount       Decimal  @db.Decimal(10, 2)
  optionalExtrasAmount       Decimal  @db.Decimal(10, 2)
  customerTotalAmount        Decimal  @db.Decimal(10, 2)
  providerExpectedPayout     Decimal  @db.Decimal(10, 2)
  pricingJson                Json?
  createdAt                  DateTime @default(now())
  booking                    Booking  @relation(fields: [bookingId], references: [id])
}

model PaymentRecord {
  id                         String          @id @default(cuid())
  bookingId                  String
  stripeAccountId            String?
  stripeCheckoutSessionId    String?         @unique
  stripePaymentIntentId      String?         @unique
  stripeChargeId             String?         @unique
  stripeBalanceTransactionId String?         @unique
  paymentState               PaymentStatus   @default(PENDING)
  grossAmount                Decimal         @db.Decimal(10, 2)
  applicationFeeAmount       Decimal?        @db.Decimal(10, 2)
  stripeFeeEstimate          Decimal?        @db.Decimal(10, 2)
  stripeFeeActual            Decimal?        @db.Decimal(10, 2)
  metadataJson               Json?
  createdAt                  DateTime        @default(now())
  updatedAt                  DateTime        @updatedAt
  booking                    Booking         @relation(fields: [bookingId], references: [id])
}

model RefundRecord {
  id                    String          @id @default(cuid())
  bookingId             String
  paymentRecordId       String?
  stripeRefundId        String?         @unique
  refundReason          String?
  amount                Decimal         @db.Decimal(10, 2)
  liability             RefundLiability @default(PLATFORM)
  refundApplicationFee  Boolean         @default(false)
  status                RefundStatus    @default(PENDING)
  actorId               String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  booking               Booking         @relation(fields: [bookingId], references: [id])
}

model DisputeRecord {
  id                      String             @id @default(cuid())
  bookingId               String
  providerCompanyId       String?
  stripeDisputeId         String?            @unique
  status                  DisputeCaseStatus  @default(OPEN)
  amount                  Decimal            @db.Decimal(10, 2)
  reason                  String?
  evidenceJson            Json?
  platformAbsorbsLoss     Boolean            @default(false)
  recoverableFromProvider Decimal?           @db.Decimal(10, 2)
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  booking                 Booking            @relation(fields: [bookingId], references: [id])
  providerCompany         ProviderCompany?   @relation(fields: [providerCompanyId], references: [id])
}

model PayoutRecord {
  id                String               @id @default(cuid())
  bookingId         String
  providerCompanyId String
  stripePayoutId    String?              @unique
  status            ProviderPayoutStatus @default(PENDING)
  amount            Decimal              @db.Decimal(10, 2)
  availableOn       DateTime?
  paidAt            DateTime?
  failureCode       String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  booking           Booking              @relation(fields: [bookingId], references: [id])
  providerCompany   ProviderCompany      @relation(fields: [providerCompanyId], references: [id])
}

model LedgerEntry {
  id          String          @id @default(cuid())
  bookingId   String
  kind        LedgerEntryKind
  amount      Decimal         @db.Decimal(10, 2)
  currency    String          @default("GBP")
  description String
  metadataJson Json?
  createdAt   DateTime        @default(now())
  booking     Booking         @relation(fields: [bookingId], references: [id])
}

model InvoiceRecord {
  id                String          @id @default(cuid())
  bookingId         String?
  providerCompanyId String?
  number            String          @unique
  strategy          InvoiceStrategy
  issuer            String
  recipient         String
  totalAmount       Decimal         @db.Decimal(10, 2)
  currency          String          @default("GBP")
  pdfUrl            String?
  metadataJson      Json?
  createdAt         DateTime        @default(now())
  booking           Booking?        @relation(fields: [bookingId], references: [id])
  providerCompany   ProviderCompany? @relation(fields: [providerCompanyId], references: [id])
}

model NotificationLogV2 {
  id                String              @id @default(cuid())
  bookingId         String?
  providerCompanyId String?
  channel           NotificationChannel
  status            NotificationStatus  @default(QUEUED)
  recipient         String
  subject           String?
  templateCode      String?
  payloadJson       Json?
  createdAt         DateTime            @default(now())
  booking           Booking?            @relation(fields: [bookingId], references: [id])
  providerCompany   ProviderCompany?    @relation(fields: [providerCompanyId], references: [id])
}

model WebhookEvent {
  id              String          @id @default(cuid())
  provider        WebhookProvider
  externalEventId String          @unique
  eventType       String
  status          WebhookProcessingStatus @default(RECEIVED)
  processed       Boolean         @default(false)
  payloadJson     Json
  receivedAt      DateTime        @default(now())
  processedAt     DateTime?
  errorMessage    String?
}

model AdminSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  valueJson   Json
  description String?
  updatedAt   DateTime @updatedAt
}

{
  "name": "areasorted-provider-app",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "prebuild": "expo prebuild --clean",
    "build:android:preview": "npx eas-cli build --platform android --profile preview",
    "build:ios:preview": "npx eas-cli build --platform ios --profile preview",
    "doctor": "npx expo-doctor",
    "submit:android": "npx eas-cli submit --platform android --profile production",
    "submit:ios": "npx eas-cli submit --platform ios --profile production"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "expo": "~53.0.17",
    "expo-constants": "~17.1.6",
    "expo-device": "~7.1.4",
    "expo-font": "~13.3.2",
    "expo-linking": "~7.1.7",
    "expo-notifications": "~0.31.4",
    "expo-router": "~5.1.3",
    "expo-secure-store": "~14.2.3",
    "expo-status-bar": "~2.2.3",
    "react": "19.0.0",
    "react-native": "0.79.6",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~19.0.10",
    "expo-doctor": "^1.17.11",
    "typescript": "~5.8.3"
  }
}
